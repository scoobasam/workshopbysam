---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { experiments } from '../../data/experiments.js';
---
<BaseLayout title="Experiments" description="Interactive demos and design explorations.">
  <section class="hero" style="padding: 32px 0 24px;">
    <div class="eyebrow">index</div>
    <h1 class="display" style="font-size: clamp(40px, 8vw, 96px);">
      the <span class="word">experiments</span>.
    </h1>
    <p class="lede">
      Every experiment is a self-contained page. Poke at them. Break them. Steal the ideas.
    </p>
  </section>

  <section style="margin-top: 20px;">
    <div class="grid">
      {experiments.map((e) => (
        <a class={`card is-${e.tone}`} href={`${import.meta.env.BASE_URL}experiments/${e.slug}`}>
          <div class="stack-md">
            <div class="meta">
              {e.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <h3>{e.title}</h3>
            <p>{e.description}</p>
          </div>
          <div class="footer-row">
            <span>{e.date}</span>
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
