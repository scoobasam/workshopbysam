---
// src/pages/experiments/index.astro
// Standalone /experiments page. Same grid as the homepage, but framed
// as a dedicated index rather than the welcome page. Skip this file if
// you don't currently have an /experiments index in the live site.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperimentCard from '../../components/ExperimentCard.astro';
import { experiments } from '../../data/experiments.js';

const count = experiments.length === 1 ? '1 work' : `${experiments.length} works`;
---
<BaseLayout title="Experiments">
  <section class="page-header">
    <p class="eyebrow">Index</p>
    <h1>Experiments</h1>
    <p class="lede">Everything currently in the lab. Hover a card to follow it through.</p>
  </section>

  <div class="count-row">
    <span class="count-meta">{count}</span>
    <span class="count-meta">All time</span>
  </div>

  <div class="grid">
    {experiments.map((exp, i) => (
      <ExperimentCard
        slug={exp.slug}
        title={exp.title}
        description={exp.description}
        tags={exp.tags}
        tone={exp.tone}
        index={i + 1}
      />
    ))}
  </div>
</BaseLayout>
