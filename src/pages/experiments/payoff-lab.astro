---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
---
<ExperimentLayout
  title="Payoff Lab"
  description="Stack option legs and watch the combined P&L curve emerge at expiration. Drag the strikes, read off the breakevens."
  tags={['finance', 'options', 'svg']}
  date="2026-04"
>
  <div class="experiment-body payoff-body">

    <!-- Stats strip -->
    <div class="stats-strip" id="stats-strip">
      <div class="stat"><span class="stat-label">Net cost</span><span class="stat-value" id="stat-cost">—</span></div>
      <div class="stat"><span class="stat-label">Max profit</span><span class="stat-value pos" id="stat-max">—</span></div>
      <div class="stat"><span class="stat-label">Max loss</span><span class="stat-value neg" id="stat-min">—</span></div>
      <div class="stat"><span class="stat-label">Breakeven</span><span class="stat-value" id="stat-be">—</span></div>
    </div>

    <!-- Chart -->
    <div class="chart-wrap">
      <svg id="payoff-chart" viewBox="0 0 800 380" preserveAspectRatio="none" aria-label="Option payoff diagram"></svg>
      <div class="chart-tooltip" id="chart-tooltip" hidden></div>
    </div>

    <!-- Controls: presets + spot -->
    <div class="controls-row">
      <div class="presets">
        <span class="eyebrow">Preset</span>
        <div class="preset-buttons" id="preset-buttons">
          <button class="preset-btn" data-preset="long-call">Long call</button>
          <button class="preset-btn" data-preset="long-put">Long put</button>
          <button class="preset-btn" data-preset="bull-call-spread">Bull call spread</button>
          <button class="preset-btn" data-preset="bear-put-spread">Bear put spread</button>
          <button class="preset-btn" data-preset="long-straddle">Long straddle</button>
          <button class="preset-btn" data-preset="long-strangle">Long strangle</button>
          <button class="preset-btn" data-preset="iron-condor">Iron condor</button>
          <button class="preset-btn" data-preset="covered-call">Covered call</button>
          <button class="preset-btn ghost" data-preset="clear">Clear</button>
        </div>
      </div>
      <div class="spot-control">
        <label class="eyebrow" for="spot-input">Current spot</label>
        <input id="spot-input" type="number" step="0.5" value="100" />
      </div>
    </div>

    <!-- Legs editor -->
    <div class="legs-block">
      <div class="legs-header">
        <span class="eyebrow">Legs</span>
        <button class="add-leg" id="add-leg">+ Add leg</button>
      </div>
      <div class="legs-grid" id="legs-grid"></div>
    </div>

  </div>

  <section class="prose" style="margin-top: 36px;">
    <p>
      Each option leg is a piecewise-linear payoff at expiration. Stacking
      them is just addition — the combined curve is whatever you get when you
      sum every leg at every spot price.
    </p>
    <p>
      <strong>Long call:</strong> <code>max(S − K, 0) − premium</code>.
      <strong>Long put:</strong> <code>max(K − S, 0) − premium</code>.
      Short legs flip the sign. A stock leg is just <code>S − S₀</code>.
    </p>
    <p>
      Breakevens are wherever the combined curve crosses zero. Max profit and
      max loss are the extremes of the curve over the displayed range — with
      naked short calls and short puts, the displayed loss is bounded only by
      where the chart ends, not where the loss does.
    </p>
  </section>

  <style>
    .payoff-body {
      display: flex;
      flex-direction: column;
      gap: 22px;
      padding: 0;
    }

    /* Stats strip */
    .stats-strip {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }
    .stat {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 14px 16px;
      border-radius: 14px;
      background: rgba(167, 139, 250, 0.06);
      border: 1px solid rgba(167, 139, 250, 0.18);
    }
    .stat-label {
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      opacity: 0.65;
    }
    .stat-value {
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      font-size: 18px;
      font-variant-numeric: tabular-nums;
    }
    .stat-value.pos { color: #16a34a; }
    .stat-value.neg { color: #dc2626; }
    @media (prefers-color-scheme: dark) {
      .stat-value.pos { color: #4ade80; }
      .stat-value.neg { color: #fb7185; }
    }

    /* Chart */
    .chart-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 800 / 380;
      min-height: 320px;
      border-radius: 18px;
      background: rgba(167, 139, 250, 0.04);
      border: 1px solid rgba(167, 139, 250, 0.18);
      overflow: hidden;
    }
    #payoff-chart {
      width: 100%;
      height: 100%;
      display: block;
    }
    .chart-tooltip {
      position: absolute;
      pointer-events: none;
      background: rgba(20, 14, 36, 0.92);
      color: #fff;
      padding: 8px 11px;
      border-radius: 10px;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 11px;
      letter-spacing: 0.04em;
      transform: translate(-50%, -120%);
      white-space: nowrap;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
    }

    /* Controls row */
    .controls-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 18px;
      align-items: end;
    }
    .eyebrow {
      display: block;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      opacity: 0.6;
      margin-bottom: 8px;
    }
    .preset-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .preset-btn {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 11px;
      letter-spacing: 0.06em;
      padding: 7px 12px;
      background: rgba(167, 139, 250, 0.07);
      border: 1px solid rgba(167, 139, 250, 0.25);
      border-radius: 999px;
      color: inherit;
      cursor: pointer;
      transition: background 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
    }
    .preset-btn:hover {
      background: rgba(167, 139, 250, 0.18);
      border-color: rgba(167, 139, 250, 0.5);
    }
    .preset-btn:active { transform: translateY(1px); }
    .preset-btn.ghost {
      background: transparent;
      border-color: rgba(127, 127, 127, 0.3);
      opacity: 0.7;
    }
    .spot-control input {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 16px;
      width: 110px;
      padding: 8px 10px;
      border-radius: 10px;
      border: 1px solid rgba(167, 139, 250, 0.3);
      background: rgba(167, 139, 250, 0.06);
      color: inherit;
    }
    .spot-control input:focus {
      outline: none;
      border-color: rgba(167, 139, 250, 0.7);
    }

    /* Legs */
    .legs-block { display: flex; flex-direction: column; gap: 10px; }
    .legs-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .add-leg {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 11px;
      letter-spacing: 0.08em;
      padding: 6px 14px;
      background: rgba(167, 139, 250, 0.12);
      border: 1px dashed rgba(167, 139, 250, 0.45);
      border-radius: 999px;
      color: inherit;
      cursor: pointer;
    }
    .add-leg:hover { background: rgba(167, 139, 250, 0.22); }
    .legs-grid { display: grid; gap: 8px; }
    .leg-row {
      display: grid;
      grid-template-columns: 90px 90px 1fr 1fr 80px 32px;
      gap: 8px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(167, 139, 250, 0.05);
      border: 1px solid rgba(167, 139, 250, 0.18);
    }
    .leg-row select,
    .leg-row input {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 13px;
      padding: 6px 8px;
      border-radius: 8px;
      border: 1px solid rgba(167, 139, 250, 0.25);
      background: rgba(255, 255, 255, 0.05);
      color: inherit;
      width: 100%;
      box-sizing: border-box;
    }
    @media (prefers-color-scheme: light) {
      .leg-row select,
      .leg-row input {
        background: rgba(255, 255, 255, 0.7);
      }
    }
    .leg-row select:focus,
    .leg-row input:focus {
      outline: none;
      border-color: rgba(167, 139, 250, 0.7);
    }
    .leg-field {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .leg-field-label {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0.55;
    }
    .leg-delete {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      border: 1px solid rgba(127, 127, 127, 0.25);
      background: transparent;
      color: inherit;
      cursor: pointer;
      font-size: 14px;
      line-height: 1;
      opacity: 0.6;
      transition: all 0.15s ease;
    }
    .leg-delete:hover {
      opacity: 1;
      border-color: #dc2626;
      color: #dc2626;
    }
    .empty-legs {
      padding: 18px;
      text-align: center;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 12px;
      opacity: 0.6;
      border: 1px dashed rgba(127, 127, 127, 0.3);
      border-radius: 12px;
    }

    /* Responsive */
    @media (max-width: 640px) {
      .stats-strip { grid-template-columns: repeat(2, 1fr); }
      .controls-row { grid-template-columns: 1fr; align-items: start; }
      .leg-row {
        grid-template-columns: 1fr 1fr;
        grid-auto-rows: auto;
      }
      .leg-delete {
        grid-column: 2;
        justify-self: end;
      }
    }
  </style>

  <script is:inline>
    (() => {
      // ----- state -----
      let legs = [];
      let spot = 100;
      let hover = null; // {x, y} in svg coords or null

      const SVG = document.getElementById('payoff-chart');
      const TOOLTIP = document.getElementById('chart-tooltip');
      const LEGS_GRID = document.getElementById('legs-grid');

      const VB = { w: 800, h: 380, pl: 56, pr: 24, pt: 22, pb: 38 };
      const PLOT_W = VB.w - VB.pl - VB.pr;
      const PLOT_H = VB.h - VB.pt - VB.pb;

      // ----- presets -----
      const PRESETS = {
        'long-call':         () => [{ kind: 'call', side: 'long',  strike: 100, premium: 4, qty: 1 }],
        'long-put':          () => [{ kind: 'put',  side: 'long',  strike: 100, premium: 4, qty: 1 }],
        'bull-call-spread':  () => [
          { kind: 'call', side: 'long',  strike: 95,  premium: 6, qty: 1 },
          { kind: 'call', side: 'short', strike: 105, premium: 2, qty: 1 },
        ],
        'bear-put-spread':   () => [
          { kind: 'put', side: 'long',  strike: 105, premium: 6, qty: 1 },
          { kind: 'put', side: 'short', strike: 95,  premium: 2, qty: 1 },
        ],
        'long-straddle':     () => [
          { kind: 'call', side: 'long', strike: 100, premium: 4, qty: 1 },
          { kind: 'put',  side: 'long', strike: 100, premium: 4, qty: 1 },
        ],
        'long-strangle':     () => [
          { kind: 'call', side: 'long', strike: 105, premium: 3, qty: 1 },
          { kind: 'put',  side: 'long', strike: 95,  premium: 3, qty: 1 },
        ],
        'iron-condor':       () => [
          { kind: 'put',  side: 'long',  strike: 90,  premium: 1, qty: 1 },
          { kind: 'put',  side: 'short', strike: 95,  premium: 2, qty: 1 },
          { kind: 'call', side: 'short', strike: 105, premium: 2, qty: 1 },
          { kind: 'call', side: 'long',  strike: 110, premium: 1, qty: 1 },
        ],
        'covered-call':      () => [
          { kind: 'stock', side: 'long', entry: 100, qty: 1 },
          { kind: 'call',  side: 'short', strike: 105, premium: 3, qty: 1 },
        ],
        'clear':             () => [],
      };

      // ----- math -----
      function legPayoff(leg, S) {
        const sign = leg.side === 'long' ? 1 : -1;
        const q = +leg.qty || 0;
        if (leg.kind === 'call') {
          return sign * (Math.max(S - (+leg.strike || 0), 0) - (+leg.premium || 0)) * q;
        }
        if (leg.kind === 'put') {
          return sign * (Math.max((+leg.strike || 0) - S, 0) - (+leg.premium || 0)) * q;
        }
        if (leg.kind === 'stock') {
          return sign * (S - (+leg.entry || 0)) * q;
        }
        return 0;
      }
      function totalPayoff(S) {
        let sum = 0;
        for (const leg of legs) sum += legPayoff(leg, S);
        return sum;
      }
      function netCost() {
        // +cost = debit (you paid), -cost = credit (you received)
        let c = 0;
        for (const leg of legs) {
          const q = +leg.qty || 0;
          const sign = leg.side === 'long' ? 1 : -1;
          if (leg.kind === 'call' || leg.kind === 'put') {
            c += sign * (+leg.premium || 0) * q;
          } else if (leg.kind === 'stock') {
            c += sign * (+leg.entry || 0) * q;
          }
        }
        return c;
      }

      function getXRange() {
        const points = [];
        for (const leg of legs) {
          if (leg.kind === 'stock') points.push(+leg.entry || 0);
          else points.push(+leg.strike || 0);
        }
        if (points.length === 0) return [spot * 0.5, spot * 1.5];
        const lo = Math.min(...points, spot);
        const hi = Math.max(...points, spot);
        const span = Math.max(hi - lo, spot * 0.2, 1);
        return [Math.max(0, lo - span * 0.4), hi + span * 0.4];
      }

      function sample(xMin, xMax, n) {
        const out = [];
        // include strikes as exact samples so the kinks are sharp
        const kinks = new Set();
        for (const leg of legs) {
          if (leg.kind === 'stock') kinks.add(+leg.entry || 0);
          else kinks.add(+leg.strike || 0);
        }
        kinks.add(spot);
        const xs = [];
        for (let i = 0; i < n; i++) xs.push(xMin + (i / (n - 1)) * (xMax - xMin));
        for (const k of kinks) if (k >= xMin && k <= xMax) xs.push(k);
        xs.sort((a, b) => a - b);
        for (const x of xs) out.push({ x, y: totalPayoff(x) });
        return out;
      }

      function findBreakevens(samples) {
        const out = [];
        for (let i = 1; i < samples.length; i++) {
          const a = samples[i - 1], b = samples[i];
          if (a.y === 0) out.push(a.x);
          else if ((a.y < 0 && b.y > 0) || (a.y > 0 && b.y < 0)) {
            const t = a.y / (a.y - b.y);
            out.push(a.x + t * (b.x - a.x));
          }
        }
        // dedupe close values
        const dedup = [];
        for (const v of out) {
          if (!dedup.some((d) => Math.abs(d - v) < 1e-3)) dedup.push(v);
        }
        return dedup;
      }

      function fmtMoney(n) {
        if (!isFinite(n)) return '—';
        const sign = n < 0 ? '−' : '';
        const abs = Math.abs(n);
        return sign + '$' + abs.toFixed(2);
      }
      function fmtSpot(n) { return '$' + (+n).toFixed(2); }

      // ----- render: legs editor -----
      function renderLegs() {
        LEGS_GRID.innerHTML = '';
        if (legs.length === 0) {
          const empty = document.createElement('div');
          empty.className = 'empty-legs';
          empty.textContent = 'No legs yet — pick a preset or add one.';
          LEGS_GRID.appendChild(empty);
          return;
        }
        legs.forEach((leg, i) => {
          const row = document.createElement('div');
          row.className = 'leg-row';

          const isStock = leg.kind === 'stock';

          row.innerHTML = `
            <div class="leg-field">
              <span class="leg-field-label">Type</span>
              <select data-i="${i}" data-k="kind">
                <option value="call" ${leg.kind === 'call' ? 'selected' : ''}>Call</option>
                <option value="put" ${leg.kind === 'put' ? 'selected' : ''}>Put</option>
                <option value="stock" ${leg.kind === 'stock' ? 'selected' : ''}>Stock</option>
              </select>
            </div>
            <div class="leg-field">
              <span class="leg-field-label">Side</span>
              <select data-i="${i}" data-k="side">
                <option value="long" ${leg.side === 'long' ? 'selected' : ''}>Long</option>
                <option value="short" ${leg.side === 'short' ? 'selected' : ''}>Short</option>
              </select>
            </div>
            <div class="leg-field">
              <span class="leg-field-label">${isStock ? 'Entry' : 'Strike'}</span>
              <input data-i="${i}" data-k="${isStock ? 'entry' : 'strike'}" type="number" step="0.5" value="${isStock ? (leg.entry ?? 100) : (leg.strike ?? 100)}" />
            </div>
            <div class="leg-field">
              <span class="leg-field-label">${isStock ? '(none)' : 'Premium'}</span>
              <input data-i="${i}" data-k="premium" type="number" step="0.1" value="${leg.premium ?? 0}" ${isStock ? 'disabled placeholder="—"' : ''} />
            </div>
            <div class="leg-field">
              <span class="leg-field-label">Qty</span>
              <input data-i="${i}" data-k="qty" type="number" step="1" min="0" value="${leg.qty ?? 1}" />
            </div>
            <button class="leg-delete" data-del="${i}" title="Remove leg">×</button>
          `;
          LEGS_GRID.appendChild(row);
        });
      }

      LEGS_GRID.addEventListener('input', (e) => {
        const t = e.target;
        const i = t.getAttribute && t.getAttribute('data-i');
        const k = t.getAttribute && t.getAttribute('data-k');
        if (i == null || k == null) return;
        const leg = legs[+i];
        if (!leg) return;
        if (k === 'kind') {
          leg.kind = t.value;
          if (leg.kind === 'stock') {
            leg.entry = leg.entry ?? leg.strike ?? 100;
            delete leg.strike;
          } else {
            leg.strike = leg.strike ?? leg.entry ?? 100;
            delete leg.entry;
          }
          renderLegs();
        } else if (k === 'side') {
          leg.side = t.value;
        } else {
          leg[k] = t.value === '' ? '' : +t.value;
        }
        render();
      });
      LEGS_GRID.addEventListener('click', (e) => {
        const t = e.target;
        const del = t.getAttribute && t.getAttribute('data-del');
        if (del != null) {
          legs.splice(+del, 1);
          renderLegs();
          render();
        }
      });

      // ----- render: chart -----
      function render() {
        const [xMin, xMax] = getXRange();
        const samples = sample(xMin, xMax, 360);

        // y range
        let yMin = 0, yMax = 0;
        for (const s of samples) {
          if (s.y < yMin) yMin = s.y;
          if (s.y > yMax) yMax = s.y;
        }
        if (yMin === 0 && yMax === 0) { yMin = -1; yMax = 1; }
        const yPad = Math.max(Math.abs(yMin), Math.abs(yMax)) * 0.18 || 1;
        yMin -= yPad; yMax += yPad;

        const xToPx = (x) => VB.pl + ((x - xMin) / (xMax - xMin)) * PLOT_W;
        const yToPx = (y) => VB.pt + ((yMax - y) / (yMax - yMin)) * PLOT_H;

        // Build paths
        let curveD = '';
        let posD = '';
        let negD = '';
        const zeroPx = yToPx(0);

        // For positive/negative fills, we walk the samples, and split when the
        // curve crosses zero — interpolating an exact zero crossing point.
        const crossings = [];
        for (let i = 0; i < samples.length; i++) {
          const s = samples[i];
          const px = xToPx(s.x);
          const py = yToPx(s.y);
          curveD += (i === 0 ? 'M' : 'L') + px.toFixed(2) + ' ' + py.toFixed(2);
        }

        // Build region paths by segmenting on zero crossings
        function buildRegion(positive) {
          let d = '';
          let inRegion = false;
          let regionStartPx = 0;
          for (let i = 0; i < samples.length; i++) {
            const s = samples[i];
            const isIn = positive ? s.y >= 0 : s.y <= 0;
            const px = xToPx(s.x);
            const py = yToPx(s.y);
            if (isIn && !inRegion) {
              // entry — interpolate from previous if needed
              if (i > 0) {
                const prev = samples[i - 1];
                if ((prev.y < 0 && s.y >= 0) || (prev.y > 0 && s.y <= 0)) {
                  const t = prev.y / (prev.y - s.y);
                  const xCross = prev.x + t * (s.x - prev.x);
                  const cpx = xToPx(xCross);
                  d += 'M' + cpx.toFixed(2) + ' ' + zeroPx.toFixed(2);
                  d += 'L' + px.toFixed(2) + ' ' + py.toFixed(2);
                  regionStartPx = cpx;
                  inRegion = true;
                  continue;
                }
              }
              d += 'M' + px.toFixed(2) + ' ' + zeroPx.toFixed(2);
              d += 'L' + px.toFixed(2) + ' ' + py.toFixed(2);
              regionStartPx = px;
              inRegion = true;
            } else if (isIn && inRegion) {
              d += 'L' + px.toFixed(2) + ' ' + py.toFixed(2);
            } else if (!isIn && inRegion) {
              // exit — interpolate
              const prev = samples[i - 1];
              const t = prev.y / (prev.y - s.y);
              const xCross = prev.x + t * (s.x - prev.x);
              const cpx = xToPx(xCross);
              d += 'L' + cpx.toFixed(2) + ' ' + zeroPx.toFixed(2);
              d += 'Z';
              inRegion = false;
            }
          }
          if (inRegion) {
            const last = samples[samples.length - 1];
            d += 'L' + xToPx(last.x).toFixed(2) + ' ' + zeroPx.toFixed(2);
            d += 'Z';
          }
          return d;
        }
        posD = buildRegion(true);
        negD = buildRegion(false);

        // Axes
        // X ticks: ~6 nice values
        const xTicks = niceTicks(xMin, xMax, 6);
        const yTicks = niceTicks(yMin, yMax, 5);

        // Strikes / spot markers
        const strikes = [];
        for (const leg of legs) {
          if (leg.kind === 'stock') strikes.push({ v: +leg.entry || 0, label: 'S₀' });
          else strikes.push({ v: +leg.strike || 0, label: 'K' });
        }

        // Breakevens
        const bes = findBreakevens(samples);

        // Build SVG
        const parts = [];
        // grid
        for (const t of yTicks) {
          const py = yToPx(t);
          parts.push(`<line x1="${VB.pl}" x2="${VB.pl + PLOT_W}" y1="${py}" y2="${py}" stroke="currentColor" stroke-width="0.5" opacity="${t === 0 ? 0.5 : 0.12}"/>`);
          parts.push(`<text x="${VB.pl - 8}" y="${py + 4}" text-anchor="end" font-family="ui-monospace, monospace" font-size="10" fill="currentColor" opacity="0.7">${formatTick(t)}</text>`);
        }
        for (const t of xTicks) {
          const px = xToPx(t);
          parts.push(`<line x1="${px}" x2="${px}" y1="${VB.pt}" y2="${VB.pt + PLOT_H}" stroke="currentColor" stroke-width="0.5" opacity="0.08"/>`);
          parts.push(`<text x="${px}" y="${VB.pt + PLOT_H + 18}" text-anchor="middle" font-family="ui-monospace, monospace" font-size="10" fill="currentColor" opacity="0.7">${formatTick(t)}</text>`);
        }

        // axis labels
        parts.push(`<text x="${VB.pl + PLOT_W / 2}" y="${VB.h - 4}" text-anchor="middle" font-family="ui-monospace, monospace" font-size="9" fill="currentColor" opacity="0.5" letter-spacing="2">SPOT AT EXPIRATION</text>`);
        parts.push(`<text x="14" y="${VB.pt + PLOT_H / 2}" text-anchor="middle" font-family="ui-monospace, monospace" font-size="9" fill="currentColor" opacity="0.5" letter-spacing="2" transform="rotate(-90 14 ${VB.pt + PLOT_H / 2})">PROFIT &amp; LOSS</text>`);

        // strike markers
        for (const s of strikes) {
          if (s.v < xMin || s.v > xMax) continue;
          const px = xToPx(s.v);
          parts.push(`<line x1="${px}" x2="${px}" y1="${VB.pt}" y2="${VB.pt + PLOT_H}" stroke="rgb(167,139,250)" stroke-width="1" stroke-dasharray="3 4" opacity="0.45"/>`);
        }

        // spot marker
        if (spot >= xMin && spot <= xMax) {
          const px = xToPx(spot);
          parts.push(`<line x1="${px}" x2="${px}" y1="${VB.pt}" y2="${VB.pt + PLOT_H}" stroke="currentColor" stroke-width="1" stroke-dasharray="2 3" opacity="0.5"/>`);
          parts.push(`<text x="${px}" y="${VB.pt - 6}" text-anchor="middle" font-family="ui-monospace, monospace" font-size="9" letter-spacing="1.5" fill="currentColor" opacity="0.6">SPOT</text>`);
        }

        // fills
        if (posD) parts.push(`<path d="${posD}" fill="rgba(34,197,94,0.18)" stroke="none"/>`);
        if (negD) parts.push(`<path d="${negD}" fill="rgba(239,68,68,0.18)" stroke="none"/>`);

        // curve
        parts.push(`<path d="${curveD}" fill="none" stroke="rgb(139,92,246)" stroke-width="2.4" stroke-linejoin="round" stroke-linecap="round"/>`);

        // breakevens
        for (const v of bes) {
          if (v < xMin || v > xMax) continue;
          const px = xToPx(v);
          parts.push(`<circle cx="${px}" cy="${zeroPx}" r="4.5" fill="rgb(139,92,246)" stroke="white" stroke-width="1.5"/>`);
          parts.push(`<text x="${px}" y="${zeroPx + 18}" text-anchor="middle" font-family="ui-monospace, monospace" font-size="9.5" fill="currentColor" opacity="0.85">${formatTick(v)}</text>`);
        }

        // hover crosshair
        if (hover) {
          const { svgX } = hover;
          if (svgX >= VB.pl && svgX <= VB.pl + PLOT_W) {
            const xVal = xMin + ((svgX - VB.pl) / PLOT_W) * (xMax - xMin);
            const yVal = totalPayoff(xVal);
            const py = yToPx(yVal);
            parts.push(`<line x1="${svgX}" x2="${svgX}" y1="${VB.pt}" y2="${VB.pt + PLOT_H}" stroke="currentColor" stroke-width="0.7" opacity="0.4"/>`);
            parts.push(`<circle cx="${svgX}" cy="${py}" r="4.5" fill="white" stroke="rgb(139,92,246)" stroke-width="2"/>`);
            // tooltip via DOM
            const rect = SVG.getBoundingClientRect();
            const px = (svgX / VB.w) * rect.width;
            const py2 = (py / VB.h) * rect.height;
            TOOLTIP.hidden = false;
            TOOLTIP.style.left = px + 'px';
            TOOLTIP.style.top = py2 + 'px';
            TOOLTIP.innerHTML = `<strong>${fmtSpot(xVal)}</strong> &middot; ${fmtMoney(yVal)}`;
          } else {
            TOOLTIP.hidden = true;
          }
        } else {
          TOOLTIP.hidden = true;
        }

        SVG.innerHTML = parts.join('');

        // Stats
        const cost = netCost();
        let mx = -Infinity, mn = Infinity;
        for (const s of samples) {
          if (s.y > mx) mx = s.y;
          if (s.y < mn) mn = s.y;
        }
        document.getElementById('stat-cost').textContent =
          legs.length === 0 ? '—' : (cost > 0 ? `${fmtMoney(cost)} debit` : cost < 0 ? `${fmtMoney(-cost)} credit` : '$0.00');
        document.getElementById('stat-max').textContent = legs.length === 0 ? '—' : fmtMoney(mx);
        document.getElementById('stat-min').textContent = legs.length === 0 ? '—' : fmtMoney(mn);
        document.getElementById('stat-be').textContent = bes.length === 0 ? (legs.length === 0 ? '—' : 'none') : bes.map((v) => fmtSpot(v)).join('  ·  ');
      }

      function niceTicks(min, max, count) {
        const span = max - min;
        if (span <= 0) return [min];
        const step0 = span / count;
        const mag = Math.pow(10, Math.floor(Math.log10(step0)));
        const norm = step0 / mag;
        let step;
        if (norm < 1.5) step = 1 * mag;
        else if (norm < 3) step = 2 * mag;
        else if (norm < 7) step = 5 * mag;
        else step = 10 * mag;
        const start = Math.ceil(min / step) * step;
        const out = [];
        for (let v = start; v <= max + step * 0.001; v += step) out.push(+v.toFixed(10));
        return out;
      }
      function formatTick(v) {
        if (Math.abs(v) >= 1000) return (v / 1000).toFixed(1) + 'k';
        if (Math.abs(v) >= 100) return v.toFixed(0);
        if (Math.abs(v) >= 10) return v.toFixed(1);
        return v.toFixed(2);
      }

      // ----- presets / add / spot -----
      document.getElementById('preset-buttons').addEventListener('click', (e) => {
        const t = e.target.closest('.preset-btn');
        if (!t) return;
        const key = t.getAttribute('data-preset');
        if (PRESETS[key]) {
          legs = PRESETS[key]();
          renderLegs();
          render();
        }
      });
      document.getElementById('add-leg').addEventListener('click', () => {
        legs.push({ kind: 'call', side: 'long', strike: spot, premium: 2, qty: 1 });
        renderLegs();
        render();
      });
      document.getElementById('spot-input').addEventListener('input', (e) => {
        const v = +e.target.value;
        if (isFinite(v)) { spot = v; render(); }
      });

      // ----- hover -----
      function svgPointFromEvent(e) {
        const rect = SVG.getBoundingClientRect();
        const xRel = (e.clientX - rect.left) / rect.width;
        const yRel = (e.clientY - rect.top) / rect.height;
        return { svgX: xRel * VB.w, svgY: yRel * VB.h };
      }
      SVG.addEventListener('pointermove', (e) => {
        hover = svgPointFromEvent(e);
        render();
      });
      SVG.addEventListener('pointerleave', () => {
        hover = null;
        render();
      });

      // ----- init -----
      legs = PRESETS['bull-call-spread']();
      renderLegs();
      render();
    })();
  </script>
</ExperimentLayout>
