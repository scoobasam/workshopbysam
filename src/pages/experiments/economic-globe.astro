---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';

const src = `${import.meta.env.BASE_URL}economic-globe.html`;
---
<ExperimentLayout
  title="Economic News Globe"
  description="Rotatable 3D Earth with glowing hotspots on 22 major economies. Click one to load that country’s latest business headlines."
  tags={['three.js', 'data viz', 'news api']}
  date="2026-04"
>
  <div class="experiment-body" style="padding: 0; min-height: 78vh;">
    <iframe
      src={src}
      title="Economic News Globe"
      style="width: 100%; height: 78vh; min-height: 560px; border: 0; display: block;"
      allow="accelerometer; gyroscope"
    ></iframe>
  </div>

  <section class="prose" style="margin-top: 28px;">
    <p>
      A Three.js Earth with pulsing markers over the G20 plus key financial hubs
      (Hong Kong, Singapore, Switzerland, UAE, Netherlands). Hovering shows the
      city; clicking fetches the latest <em>business</em> headlines from NewsAPI
      for that country.
    </p>
    <p>
      Without an API key it falls back to curated sample headlines so the demo
      always works. With a key (paste it in the input at the top of the embedded
      globe), it pulls live data &mdash; though NewsAPI's free tier only allows
      requests from <code>localhost</code>.
    </p>
  </section>
</ExperimentLayout>
