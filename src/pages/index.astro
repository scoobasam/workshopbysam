---
// src/pages/index.astro
// Homepage — hero + experiments grid. Reads from src/data/experiments.js
// so adding a new experiment to that file makes it appear here automatically.
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import { experiments } from '../data/experiments.js';

// Latest "updated" stamp, derived from experiment dates (YYYY-MM).
const latest = [...experiments].sort((a, b) => b.date.localeCompare(a.date))[0];
const [yyyy, mm] = (latest?.date ?? '2026-04').split('-');
const monthShort = new Date(Number(yyyy), Number(mm) - 1, 1).toLocaleString('en', { month: 'short' });
const updated = `${monthShort} ${yyyy}`;

const entry = String(experiments.length).padStart(3, '0');
const count = experiments.length === 1 ? '1 work' : `${experiments.length} works`;
---
<BaseLayout title="Workshop by Sam — a small loft for code that wonders">
  <section class="hero">
    <p class="eyebrow">Lab notebook · entry {entry}</p>
    <h1>A small loft<br />for code that <span class="warm">wonders</span>.</h1>
    <p class="lede"><strong>Experiments</strong> in motion, color, and the strange edge between data and feeling. Iterating in public, breaking things on purpose, occasionally shipping something I love.</p>
  </section>

  <div class="section-head">
    <span class="rule" aria-hidden="true"></span>
    <h2>Currently in the lab</h2>
    <span class="rule" aria-hidden="true"></span>
  </div>

  <div class="count-row">
    <span class="count-meta">{count}</span>
    <span class="count-meta">Updated {updated}</span>
  </div>

  <div class="grid">
    {experiments.map((exp, i) => (
      <ExperimentCard
        slug={exp.slug}
        title={exp.title}
        description={exp.description}
        tags={exp.tags}
        tone={exp.tone}
        index={i + 1}
      />
    ))}
  </div>
</BaseLayout>
