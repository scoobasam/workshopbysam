---
// src/components/ExperimentCard.astro
// One card in the experiments grid. Tone class drives the numeral
// color, hover glow, and border tint. The grain ::before sits
// behind everything thanks to .experiment-card > * { position: relative; }
const { slug, title, description, tags = [], tone = 'pink', index = 1 } = Astro.props;
const num = String(index).padStart(2, '0');
const base = import.meta.env.BASE_URL;
---
<a class={`experiment-card is-${tone}`} href={`${base}experiments/${slug}`}>
  <span class="num">{num}</span>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="tags">
    {tags.map((t) => <span class="tag">{t}</span>)}
  </div>
</a>
