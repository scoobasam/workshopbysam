---
// src/layouts/ExperimentLayout.astro
// Wraps an experiment page with BaseLayout chrome plus a small header
// (back link, title, description, tag pills) above the experiment slot.
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  tags?: string[];
  date?: string;
}

const { title, description, tags = [], date } = Astro.props;
const backHref = `${import.meta.env.BASE_URL}experiments`;
---
<BaseLayout title={title} description={description}>
  <section class="experiment-header">
    <a href={backHref} class="back">&larr; back to experiments</a>
    <h1>{title}</h1>
    {description ? <p class="prose">{description}</p> : null}
    <div class="row">
      {tags.map((t) => <span class="tag outline">{t}</span>)}
      {date ? <span class="tag outline date">{date}</span> : null}
    </div>
  </section>

  <slot />
</BaseLayout>

<style>
  .experiment-header {
    padding: 56px 0 40px;
    max-width: 880px;
  }
  .back {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--color-accent-cool);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 24px;
  }
  .back:hover {
    text-decoration: underline;
    text-decoration-thickness: 0.5px;
    text-underline-offset: 4px;
  }
  .experiment-header h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(36px, 5vw, 56px);
    letter-spacing: -0.02em;
    color: var(--color-text-strong);
    margin: 0 0 16px;
  }
  .prose {
    max-width: 640px;
    margin: 0 0 20px;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.6;
  }
  .row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--color-accent-cool);
    background: var(--color-tag-bg);
    padding: 4px 10px;
    border-radius: 100px;
  }
  .tag.outline {
    background: transparent;
    border: 0.5px solid var(--color-accent-cool);
  }
  .tag.date {
    color: var(--color-text);
    border-color: var(--color-rule);
  }

  @media (max-width: 720px) {
    .experiment-header { padding: 40px 0 28px; }
  }
</style>
