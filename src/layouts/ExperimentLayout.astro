---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  tags?: string[];
  date?: string;
}

const { title, description, tags = [], date } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <section class="experiment-header">
    <a href={`${import.meta.env.BASE_URL}experiments`} class="back">&larr; back to experiments</a>
    <h1>{title}</h1>
    {description ? <p class="prose" style="max-width:640px; margin:4px 0 0; color: var(--muted);">{description}</p> : null}
    <div class="row" style="margin-top:6px;">
      {tags.map((t) => <span class="tag outline">{t}</span>)}
      {date ? <span class="tag outline" style="font-family: var(--font-mono);">{date}</span> : null}
    </div>
  </section>
  <slot />
</BaseLayout>
