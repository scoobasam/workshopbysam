---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Workshop by Sam', description = 'A testing ground for interactive demos and design experiments.' } = Astro.props;
const pageTitle = title === 'Workshop by Sam' ? title : `${title} — Workshop by Sam`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700;800&display=swap"
    />
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <a href={import.meta.env.BASE_URL} class="logo">
          <span class="chip"></span>
          workshop<span style="color: var(--pink)">.</span>bysam
        </a>
        <nav class="nav">
          <a href={import.meta.env.BASE_URL}>Home</a>
          <a href={`${import.meta.env.BASE_URL}experiments`}>Experiments</a>
          <a href={`${import.meta.env.BASE_URL}about`}>About</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div>
          Built by Sam. Powered by <a href="https://astro.build">Astro</a>. Hosted on GitHub Pages.
        </div>
        <div>&copy; {new Date().getFullYear()}</div>
      </footer>
    </div>
  </body>
</html>
