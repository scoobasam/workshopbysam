---
// src/layouts/BaseLayout.astro
// Site shell — nav, footer, font preloads, grain background.
// Used by every page except the self-contained experiment pages.
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Workshop by Sam',
  description = 'A small loft for code that wonders. Experiments in motion, color, and the strange edge between data and feeling.',
} = Astro.props;

const pageTitle = title === 'Workshop by Sam' ? title : `${title} — Workshop by Sam`;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#FBF6EC" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#14110E" media="(prefers-color-scheme: dark)" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Space+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="shell">
    <nav class="site-nav">
      <a href={base} class="mark">Workshop <em>by Sam</em></a>
      <div class="nav-links">
        <a href={base}>Home</a>
        <a href={`${base}experiments`}>Experiments</a>
        <a href={`${base}about`}>About</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>Built by Sam · powered by <a href="https://astro.build">Astro</a></p>
      <p>&copy; {new Date().getFullYear()}</p>
    </footer>
  </div>
</body>
</html>

<style>
  .nav-links {
    display: flex;
    gap: 24px;
    align-items: baseline;
  }
  .nav-links a {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--color-accent-cool);
    text-decoration: none;
  }
  .nav-links a:hover {
    text-decoration: underline;
    text-decoration-thickness: 0.5px;
    text-underline-offset: 4px;
  }
  @media (max-width: 720px) {
    .nav-links { gap: 14px; }
    .nav-links a { font-size: 11px; letter-spacing: 0.08em; }
  }
</style>
